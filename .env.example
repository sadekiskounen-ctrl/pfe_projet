# ============================================================
# GitHub Secrets requis pour CI/CD
# ============================================================
# Ajoutez ces secrets dans votre repo GitHub :
# Settings → Secrets and variables → Actions → New repository secret
#
# CF_USERNAME       → Votre email SAP BTP
# CF_PASSWORD       → Votre mot de passe SAP BTP
# CF_ORG            → Nom de votre org CF (ex: trial-org)
# CF_SPACE_DEV      → Espace dev (ex: dev)
# CF_SPACE_PROD     → Espace production (ex: production)
# CF_DOMAIN         → Domaine de votre app (ex: cfapps.eu10-004.hana.ondemand.com)

# ============================================================
# Variables d'environnement locales (NE PAS COMMITTER)
# ============================================================

# SAP BTP Cloud Foundry
CF_API=https://api.cf.eu10-004.hana.ondemand.com
CF_ORG=your-trial-org
CF_SPACE_DEV=dev
CF_SPACE_PROD=production
CF_USERNAME=your-email@example.com
CF_PASSWORD=your-password

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@gestionpme.dz

# App
NODE_ENV=production
