{
  "cds.workspace.scanCsn": false,
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[cds]": {
    "editor.defaultFormatter": "SAPSE.vscode-cds"
  },
  "files.associations": {
    "*.cds": "cds"
  },
  "files.exclude": {
    "node_modules/": true,
    "gen/": true,
    "mta_archives/": true,
    "@cds-models/": true
  },
  "search.exclude": {
    "node_modules": true,
    "gen": true,
    "mta_archives": true
  }
}
